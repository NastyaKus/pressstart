# ── RAWG (база игр и обложки) ──────────────────────────────
# Бесплатный ключ: https://rawg.io/apidocs → "Get API key"
# Без ключа сайт работает на встроенном демо-наборе игр.
RAWG_API_KEY=

# ── Steam (импорт игр и часов) ─────────────────────────────
# ОДИН ключ на весь сайт, ставит владелец один раз:
# https://steamcommunity.com/dev/apikey
# После этого любой пользователь импортит свой публичный профиль без ключей.
STEAM_API_KEY=

# ── Supabase (аккаунты + сохранение данных) ────────────────
# Создай проект на https://supabase.com → Project Settings → API
# Без этих ключей вход/библиотека работать не будут (UI останется).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
